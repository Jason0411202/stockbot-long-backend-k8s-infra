# .env.example
# 複製成 .env 並填入真實密碼：cp .env.example .env
# ⚠️ .env 不會進 Git（已加入 .gitignore）

# MariaDB
MARIADB_ROOT_PASSWORD=          # MariaDB root 密碼
MARIADB_PASSWORD=               # myapp 使用者的 DB 密碼

# Grafana
GRAFANA_PASSWORD=               # Grafana Web UI 登入密碼（帳號: admin）

# Elasticsearch / Kibana
ES_PASSWORD=                    # Kibana 登入密碼（帳號: elastic）

# ArgoCD
ARGOCD_REPO_URL=                # manifest repo 的 Git URL（例：https://github.com/yourorg/xxx-manifests.git）
ARGOCD_PASSWORD=                # ArgoCD Web UI 登入密碼（帳號: admin）

# cert-manager
ACME_EMAIL=                     # Let's Encrypt 憑證申請用的 email
